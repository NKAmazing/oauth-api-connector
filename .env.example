# Spotify OAuth (https://developer.spotify.com/dashboard)
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=

# Must match exactly the redirect URI configured in the Spotify app
REDIRECT_URI=http://127.0.0.1:8000/callback/spotify

# Optional: after successful OAuth, redirect the browser here with ?session_id=...
# If unset, /callback returns JSON including session_id (useful for API clients)
# FRONTEND_SUCCESS_URL=http://127.0.0.1:3000/oauth/success
